# Watchtower local environment

WATCHTOWER_ENV=local
WATCHTOWER_HOST=127.0.0.1
WATCHTOWER_PORT=8010

# Local MVP starts with SQLite. Do not commit real local DB files.
DATABASE_URL=sqlite:///./data/watchtower.sqlite3

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# VultureInv integration
VULTUREINV_API_BASE_URL=http://127.0.0.1:8001
WATCHTOWER_API_TOKEN=

# Optional provider keys
FRED_API_KEY=
OPENDART_API_KEY=
SEC_USER_AGENT_COMPANY=VultureInv
SEC_USER_AGENT_EMAIL=

# AI / LLM policy
ENABLE_LIVE_AI=false
OPENCLAW_ENDPOINT=
OPENCLAW_MODEL=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
ENABLE_GEMINI_LIVE=false
GROK_API_KEY=
GROK_MODEL=grok-4.20
ENABLE_GROK_LIVE=false
